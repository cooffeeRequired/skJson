test "json loop":
    set {_json} to json from "{data: [{special: [1, 2, 3], player: 2}]}"

    loop values "data" of {_json}:
        assert "%json-key%" is "0" with "failing: json loop key in array"
        set {_list::*} to values "special" of json-value
        assert {_list::*} is 1, 2 and 3 with "failing: json loop values list"
